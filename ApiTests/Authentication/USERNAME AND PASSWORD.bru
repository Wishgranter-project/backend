meta {
  name: USERNAME AND PASSWORD
  type: http
  seq: 1
}

post {
  url: {{base_url}}/test/api/v1/login
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  username: adinan
  password: 123
}

script:post-response {
  var session = res.headers['set-cookie']
      ? res.headers['set-cookie'][0].match(/session=([\w\d-]+);/)[1]
      : null;
  
  if (session) {
      bru.setVar('session', session);
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
